allow-hotplug usb0
iface usb0 inet static
    address 10.42.0.2
    netmask 255.255.255.0
    network 10.42.0.0
    broadcast 10.42.0.255
    gateway 10.42.0.1
    metric 20
    dns-nameservers 8.8.8.8 1.1.1.1
    post-up /usr/local/bin/usb0-route.sh || true
    post-up echo "nameserver 8.8.8.8" > /etc/resolv.conf || true
